{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|view_image|Bash",
        "hooks": [
          {"type": "command", "command": "\"$PLUGIN_ROOT\"/scripts/images.sh"}
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {"type": "command", "command": "\"$PLUGIN_ROOT\"/scripts/diagrams.sh"}
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {"type": "command", "command": "\"$PLUGIN_ROOT\"/scripts/diagram-guidance.sh"}
        ]
      },
      {
        "hooks": [
          {"type": "command", "command": "\"$PLUGIN_ROOT\"/scripts/session-reset.sh"}
        ]
      },
      {
        "hooks": [
          {"type": "command", "command": "\"$PLUGIN_ROOT\"/scripts/session-backfill.sh"}
        ]
      }
    ]
  }
}
